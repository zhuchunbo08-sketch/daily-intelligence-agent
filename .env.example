# Basic
APP_NAME=Daily Opportunity Intel
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=Asia/Shanghai
TIMEZONE=Asia/Shanghai

# Scheduler
DAILY_RUN_HOUR=7
DAILY_RUN_MINUTE=0

# Database
DATABASE_URL=sqlite:///./daily_intelligence.db
SOURCES_CONFIG_PATH=./config/sources.json

# Report filtering
MIN_FINAL_SCORE=4.8
MAX_ITEMS_PER_REPORT=8
PUSH_DRY_RUN=false

# Unified OpenAI-compatible AI config.
# Default example uses DeepSeek. You can also switch to Qwen or OpenAI below.
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=
AI_MODEL=deepseek-v4-flash
AI_TIMEOUT_SECONDS=90

# OpenAI shortcut, kept for compatibility. Used only when AI_API_KEY is empty.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Qwen shortcut, kept for compatibility. Used only when AI_API_KEY is empty.
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# DeepSeek shortcut, kept for compatibility. Used only when AI_API_KEY is empty.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Feishu bot
FEISHU_WEBHOOK=
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
FEISHU_MAX_MESSAGE_CHARS=3500

# Email fallback
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TO=

# SMTP aliases, kept for compatibility
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Optional HTTP proxy for AI, GDELT and Feishu calls
PROXY_URL=

# Logs
LOG_FILE=./logs/app.log
